{
  "name": "lol-draft-assistant",
  "version": "1.0.0",
  "description": "AI-powered League of Legends champion-select assistant grounded in real match data — live draft suggestions, counter analysis and coaching, plus three training mini-games. Angular 21 + NgRx.",
  "author": "Víctor Esteve",
  "license": "MIT",
  "homepage": "https://lol-draft-assistant-sable.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/viictoresteve/lol-draft-assistant.git"
  },
  "keywords": [
    "league-of-legends",
    "angular",
    "ngrx",
    "ai",
    "draft",
    "champion-select"
  ],
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "proxy:dev": "cd server && npm run dev",
    "proxy:install": "cd server && npm install",
    "proxy:build": "cd server && npm run build",
    "dev": "concurrently -n \"angular,proxy\" -c \"cyan,yellow\" \"ng serve\" \"cd server && npm run dev\"",
    "lint": "ng lint"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/animations": "^21.2.18",
    "@angular/common": "^21.2.18",
    "@angular/compiler": "^21.2.18",
    "@angular/core": "^21.2.18",
    "@angular/forms": "^21.2.18",
    "@angular/platform-browser": "^21.2.18",
    "@angular/router": "^21.2.18",
    "@angular/service-worker": "^21.2.18",
    "@ngrx/effects": "^21.1.1",
    "@ngrx/store": "^21.1.1",
    "@sentry/angular": "^10.67.0",
    "html2canvas": "^1.4.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.19",
    "@angular/cli": "^21.2.19",
    "@angular/compiler-cli": "^21.2.18",
    "@eslint/js": "^10.0.1",
    "@vercel/node": "^5.8.24",
    "angular-eslint": "^21.4.0",
    "concurrently": "^10.0.3",
    "eslint": "^10.7.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
